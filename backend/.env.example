# ═══════════════════════════════════════════════════════════════════
#   Kinetic TMS — Environment Variables Template
# ═══════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values.

# ── Environment ──────────────────────────────────────────────────
ENVIRONMENT=development
DEBUG=true

# ── Database (Local Development) ─────────────────────────────────
DATABASE_URL=postgresql+asyncpg://kinetic:kinetic_dev_2024@db:5432/kinetic_tms

# ── Database (Production — Google Cloud SQL) ─────────────────────
# DATABASE_URL=postgresql+asyncpg://YOUR_DB_USER:YOUR_PASSWORD@YOUR_CLOUD_SQL_IP:5432/YOUR_DB_NAME

# ── JWT Authentication ───────────────────────────────────────────
# IMPORTANT: Change this in production!
JWT_SECRET_KEY=dev-secret-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── CORS ─────────────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:3000"]

# ── Google Cloud Storage ─────────────────────────────────────────
GCS_BUCKET_NAME=your-gcs-bucket-name
# Provide the service account key as a JSON string (recommended for containers):
GCS_CREDENTIALS_JSON=
# OR provide a file path to the service account JSON key:
GOOGLE_APPLICATION_CREDENTIALS=

# ── GCP Project ──────────────────────────────────────────────────
GCP_PROJECT_ID=your-gcp-project-id
