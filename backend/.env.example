# ═══════════════════════════════════════════════════════════════════
#   Kinetic TMS — Environment Variables Template
# ═══════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values.

# ── Environment ──────────────────────────────────────────────────
ENVIRONMENT=development
DEBUG=true

# ── Database ─────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://kinetic:kinetic_dev_2024@localhost:5432/kinetic_tms

# ── JWT Authentication ───────────────────────────────────────────
# IMPORTANT: Change this in production!
JWT_SECRET_KEY=dev-secret-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── CORS ─────────────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:3000"]

# ── Google Cloud Storage (optional — for Document Vault) ─────────
GCS_BUCKET_NAME=
GCS_CREDENTIALS_PATH=

# ── GCP Deployment (for CI/CD pipeline) ──────────────────────────
# GCP_PROJECT_ID=your-gcp-project-id
# GCP_SA_KEY=<base64-encoded service account JSON>
