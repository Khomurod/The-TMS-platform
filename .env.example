# ════════════════════════════════════════════════════════════════════
#  Safehaul TMS — Environment Variables Template
#  Copy this file to .env and fill in the values.
#  ────────────────────────────────────────────────────────────────────
#  cp .env.example .env
# ════════════════════════════════════════════════════════════════════

# ── Database ─────────────────────────────────────────────────────
# For Docker Compose local dev (default):
DATABASE_URL=postgresql+asyncpg://Safehaul:Safehaul_dev_2024@localhost:5432/Safehaul_tms

# For direct connection to Cloud SQL (remote dev):
# DATABASE_URL=postgresql+asyncpg://user:pass@HOST:5432/safehaul_tms

# ── JWT ──────────────────────────────────────────────────────────
JWT_SECRET_KEY=dev-secret-key-change-in-production

# ── Google Cloud Storage (optional for local dev) ────────────────
GCS_BUCKET_NAME=
GCS_CREDENTIALS_JSON=
GCP_PROJECT_ID=
